generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ====================== AUTH & ADMIN ======================
model User {
  id          String   @id @default(uuid())
  username    String   @unique
  email       String   @unique
  password    String
  fullName    String
  role        Role     @default(ADMIN)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("users")
}

// ====================== MAIN ENTITIES ======================
model House {
  id           String       @id @default(uuid())
  houseNumber  String       @unique
  site         String
  area         String
  floor        Int
  status       HouseStatus  @default(NONE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  lotteryResults LotteryResult[]

  @@map("houses")
  @@index([site, area])
}

model Applicant {
  id        String          @id @default(uuid())
  username  String          // Full Name
  site      String
  area      String
  status    ApplicantStatus @default(NONE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  lotteryResults LotteryResult[]

  @@map("applicants")
  @@index([site, area])
}

// ====================== LOTTERY RESULTS ======================
model LotteryResult {
  id            String       @id @default(uuid())
  lotteryRunId  String       // Groups all results from one lottery execution
  username      String
  site          String
  area          String
  floor         Int?         // nullable — waitlist entries have no house
  houseNumber   String?      // nullable — waitlist entries have no house
  status        ResultStatus
  drawDate      DateTime     @default(now())

  houseId       String?
  applicantId   String

  house         House?     @relation(fields: [houseId], references: [id])
  applicant     Applicant  @relation(fields: [applicantId], references: [id])

  @@map("lottery_results")
  @@index([lotteryRunId])
  @@index([site, area])
}

// ====================== ENUMS ======================
enum Role {
  ADMIN
  USER
}

enum HouseStatus {
  NONE
  PROVIDED
}

enum ApplicantStatus {
  NONE
  WINNER
  WAITLIST
}

enum ResultStatus {
  WINNER
  WAITLIST
}