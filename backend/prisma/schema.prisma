generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ====================== AUTH & ADMIN ======================
model User {
  id          String   @id @default(uuid())
  username    String   @unique
  email       String   @unique
  password    String
  fullName    String
  role        Role     @default(ADMIN)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("users")
}

// ====================== MAIN ENTITIES ======================
model House {
  id           String       @id @default(uuid())
  houseNumber  String       @unique
  block        String?      // Added to support the "Block" column
  bedroom      Int?         // Added to support the "Bed room" column
  site         String
  area         String
  floor        Int
  status       HouseStatus  @default(NONE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  lotteryResults LotteryResult[]

  @@map("houses")
  @@index([site, area, bedroom])
}

model Applicant {
  id        String          @id @default(uuid())
  idCode    String?         @unique // Stores the 'Id' column from the Excel sheet (e.g., 12345)
  username  String          // Maps to 'Name'
  bedroom   Int             @default(0) // 💡 ADD THIS LINE (Maps to 'Bed room')
  site      String          // Maps to 'Site'
  area      String          // Maps to 'Area'
  status    ApplicantStatus @default(NONE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  lotteryResults LotteryResult[]

  @@map("applicants")
  @@index([site, area, bedroom])
}

// ====================== LOTTERY RESULTS ======================
model LotteryResult {
  id           String   @id @default(uuid())
  lotteryRunId String
  username     String
  site         String
  area         String
  bedroom      Int      // 💡 ADD THIS LINE RIGHT HERE
  floor        Int?
  houseNumber  String?
  status       String   // "WINNER" or "WAITLIST"
  drawDate     DateTime @default(now())

  // Your existing relationships should look similar to this:
  houseId      String?
  house        House?   @relation(fields: [houseId], references: [id])
  applicantId  String
  applicant    Applicant @relation(fields: [applicantId], references: [id])
}

// ====================== ENUMS ======================
enum Role {
  ADMIN
  USER
}

enum HouseStatus {
  NONE
  PROVIDED
}

enum ApplicantStatus {
  NONE
  WINNER
  WAITLIST
}

enum ResultStatus {
  WINNER
  WAITLIST
}